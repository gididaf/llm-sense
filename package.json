{
  "name": "llm-sense",
  "version": "2.4.1",
  "description": "Analyze how LLM-friendly a codebase is — static analysis + empirical testing with Claude Code",
  "main": "dist/index.js",
  "bin": {
    "llm-sense": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node --test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepare": "husky"
  },
  "keywords": [
    "cli",
    "llm",
    "claude",
    "code-analysis",
    "context",
    "ai-friendly",
    "developer-tools"
  ],
  "author": "gididaf",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gididaf/llm-sense.git"
  },
  "bugs": {
    "url": "https://github.com/gididaf/llm-sense/issues"
  },
  "homepage": "https://github.com/gididaf/llm-sense#readme",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "web-tree-sitter": "^0.26.8",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  }
}
